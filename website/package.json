{
  "name": "website",
  "version": "0.0.6",
  "private": true,
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@10.33.4",
  "scripts": {
    "build": "next build",
    "dev": "next dev",
    "start": "serve out",
    "check:links": "linkinator \"**/*.html\" --server-root ./out --recurse --skip \"^https?://(?!localhost)\"",
    "check:links:external": "linkinator \"**/*.html\" --server-root ./out --recurse",
    "types:check": "fumadocs-mdx && next typegen && tsc --noEmit",
    "postinstall": "fumadocs-mdx",
    "lint": "eslint"
  },
  "dependencies": {
    "@orama/orama": "^3.1.18",
    "cnfast": "^0.0.8",
    "fumadocs-core": "16.11.5",
    "fumadocs-mdx": "15.2.0",
    "fumadocs-ui": "npm:@fumadocs/base-ui@16.11.5",
    "lucide-react": "^1.24.0",
    "next": "16.2.10",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.2",
    "@types/mdx": "^2.0.14",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.10",
    "linkinator": "^7.6.1",
    "postcss": "^8.5.17",
    "serve": "^14.2.6",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "unrs-resolver"
    ]
  }
}
